{
  "name": "Ant Design Compact",
  "dark": false,
  "author": "Ant Design for Swing",
  "editorScheme": "/themes/AntDesignCompact.xml",
  "colors": {
    "primaryColor":          "#1677FF",
    "primaryHoverColor":     "#4096FF",
    "primaryActiveColor":    "#0958D9",
    "primaryBgColor":        "#E6F4FF",
    "successColor":          "#52C41A",
    "successBgColor":        "#F6FFED",
    "warningColor":          "#FAAD14",
    "warningBgColor":        "#FFFBE6",
    "errorColor":            "#FF4D4F",
    "errorBgColor":          "#FFF2F0",
    "infoColor":             "#1677FF",
    "infoBgColor":           "#E6F4FF",
    "textColor":             "#0A0A0A",
    "textSecondaryColor":    "#000000A6",
    "textTertiaryColor":     "#00000073",
