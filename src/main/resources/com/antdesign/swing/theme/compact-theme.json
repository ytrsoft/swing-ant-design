      "disabledForeground":               "#00000040",
      "focusColor":                       "#1677FF",
      "focusWidth":                       2
    },
    "Button": {
      "arc":                              4,
      "background":                       "#FFFFFF",
      "foreground":                       "#0A0A0A",
      "hoverBackground":                  "#FFFFFF",
      "hoverBorderColor":                 "#4096FF",
      "pressedBackground":                "#FFFFFF",
      "focusedBorderColor":               "#1677FF",
      "borderColor":                      "#D9D9D9",
      "borderWidth":                      1,
      "default.background":               "#1677FF",
      "default.foreground":               "#FFFFFF",
      "default.hoverBackground":          "#4096FF",
      "default.pressedBackground":        "#0958D9",
